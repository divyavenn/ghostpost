# Browser settings
# Controls whether SCRAPING uses headless mode (automated tweet collection)
# - 'true' = Headless scraping (production servers without GUI)
# - 'false' = Visible browser scraping (local development/debugging)
# NOTE: User login/OAuth ALWAYS shows browser (users need to interact!)
HEADLESS_BROWSER=false
