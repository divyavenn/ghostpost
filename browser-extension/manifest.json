{
  "manifest_version": 3,
  "name": "Twitter Cookie Sync",
  "version": "1.0.0",
  "description": "Automatically sync Twitter cookies to your backend for GhostPoster",
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
