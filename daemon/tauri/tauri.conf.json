{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Consumed Daemon",
  "version": "0.1.0",
  "identifier": "com.consumed.daemon",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "assets/icon-32.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "label": "main",
        "title": "Consumed Settings",
        "width": 500,
        "height": 600,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/icon-32.png",
      "assets/icon-128.png",
      "assets/icon-256.png",
      "assets/icon.png"
    ]
  }
}
