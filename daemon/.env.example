# Copy to .env and fill in your values

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scope: repo (private) or public_repo (public)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub repo in "owner/repo" format
GITHUB_REPO=yourusername/your-diary-repo

# Path to diary/log file in repo
LOG_FILE=diary.md

# Path to Python package (optional, auto-detected)
# CONSUMED_PYTHON_DIR=/path/to/python

# Anthropic API Key (optional, enables LLM-based metadata extraction fallback)
# Create at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
