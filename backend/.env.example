# Twitter API Credentials (for future API integration)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Twitter Login Credentials (for browser automation)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# External AI Model Configuration
AI_MODEL_API_URL=https://api.your-ai-service.com
AI_MODEL_API_KEY=your_ai_model_api_key

# Agent Configuration
MAX_COMMENTS_PER_HOUR=5
MAX_COMMENTS_PER_DAY=50
MIN_COMMENT_DELAY_SECONDS=300

# Target Accounts (comma-separated)
TARGET_ACCOUNTS=elonmusk,openai,sama
